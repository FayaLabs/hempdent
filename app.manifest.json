{
  "manifestVersion": 2,
  "id": "hempdent",
  "name": "HempDent",
  "backend": {
    "provider": "supabase",
    "projectRef": "mcbfebruhimlbvlvczsn",
    "pool": "cluster-dentist-br-01",
    "tenantId": "11111111-1111-4111-8111-000000000001",
    "note": "Booking unmocked (industry pool cluster-dentist-br-01); blog/reviews/auth/payments still mock."
  },
  "locale": {
    "default": "pt-BR",
    "supported": [
      "pt-BR"
    ],
    "currency": "BRL"
  },
  "surfaces": {
    "website": {
      "scaffold": "website",
      "options": {
        "title": "HempDent",
        "description": "Site de consulta canábica do Dr. Hiago Benevenutti. Plugins Fayz curados injetados no layout customizado."
      },
      "pages": [
        {
          "id": "blog-list",
          "path": "/blog",
          "plugin": "blog",
          "label": "Blog",
          "component": "custom:BlogList"
        },
        {
          "id": "blog-post",
          "path": "/blog/:slug",
          "plugin": "blog",
          "label": "Artigo",
          "component": "custom:PostDetail"
        },
        {
          "id": "reviews",
          "path": "/reviews",
          "plugin": "reputation",
          "label": "Avaliações",
          "component": "custom:ReviewsScreen"
        },
        {
          "id": "booking",
          "path": "/agendar",
          "plugin": "booking",
          "label": "Agendamento",
          "component": "custom:BookingScreen"
        }
      ],
      "plugins": [
        {
          "id": "blog",
          "enabled": true,
          "package": "@fayz-ai/plugin-blog",
          "config": {
            "label": "Blog",
            "description": "Artigos e conteúdo educativo com autor e SEO."
          }
        },
        {
          "id": "reputation",
          "enabled": true,
          "package": "@fayz-ai/plugin-reputation",
          "config": {
            "label": "Avaliações",
            "description": "Reviews e reputação dos pacientes."
          }
        },
        {
          "id": "booking",
          "enabled": true,
          "package": "@fayz-ai/plugin-agenda",
          "config": {
            "label": "Agendamento",
            "description": "Fluxo público de agendamento com etapa de pagamento Pix."
          }
        },
        {
          "id": "payments",
          "enabled": true,
          "package": "@fayz-ai/plugin-payments",
          "config": {
            "label": "Pagamentos",
            "description": "Provider de cobrança Pix consumido pelo agendamento."
          }
        }
      ]
    }
  }
}
