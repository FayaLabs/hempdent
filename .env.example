# Hempdent — Environment Variables Example
# Copy this file to .env for local dev. In the Fayz editor these secrets are
# injected at runtime, so .env is NOT committed (see .gitignore).

# Industry-pool Supabase project backing this tenant.
# The anon/publishable key ships in the client bundle by design.
VITE_SUPABASE_URL=https://<pool-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<publishable/anon key do pool>
